# HoloBro — Holochain app interface (from `hc spin` / conductor). Copy to `.env.local` for Vite.
VITE_HC_APP_WS=ws://127.0.0.1:XXXXX
VITE_HC_APP_TOKEN=
# Optional: admin port so the UI can authorize zome signing once per session.
# VITE_HC_ADMIN_WS=ws://127.0.0.1:YYYYY
# Role name in workdir/happ.yaml (default: anon_browser)
# VITE_HC_ROLE_NAME=anon_browser
#
# Optional: encrypt chat message bodies before send_chat_message (per-thread key derivation).
# Same passphrase must be shared with peers who should read the thread.
# VITE_HC_CHAT_PASSPHRASE=your-shared-secret
#
# Optional: encrypt bookmark url+title when using “Sync bookmarks to Holochain” (envelope in DNA url field).
# Use a strong secret; anyone with it can decrypt bookmarks they can fetch from the DHT.
# VITE_HC_BOOKMARK_PASSPHRASE=another-strong-secret
